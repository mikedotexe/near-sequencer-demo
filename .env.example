# Copy to `.env` (gitignored) and fill in. The TS pipeline auto-loads `.env`
# at startup via `scripts/src/env.ts`.

# --- FastNEAR API key --------------------------------------------------------
# Optional. Get one at https://dashboard.fastnear.com. Without a key, the
# pipeline uses FastNEAR's free tier, which is usually enough for testnet but
# can rate-limit under load. With a key, requests are sent as
# `Authorization: Bearer $FASTNEAR_API_KEY` (FastNEAR also accepts
# `?apiKey=...` as a query param; we use the header form).
# One key works across RPC (rpc.mainnet.fastnear.com,
# rpc.testnet.fastnear.com) and archival (archival-rpc.mainnet.fastnear.com,
# archival-rpc.testnet.fastnear.com).
FASTNEAR_API_KEY=

# --- Network selection -------------------------------------------------------
# One of: `testnet`, `mainnet`. Defaults to `testnet`. This repo is a
# testnet-only teaching artifact; mainnet deploy is gated behind
# `--i-know-this-is-mainnet` but not recommended.
NEAR_NETWORK=testnet

# --- Optional overrides (usually leave unset) -------------------------------
# Master account that owns the two recipe-book subaccounts. Defaults based
# on network:
#   testnet → mike.testnet
#   mainnet → mike.near
# Override here if you're forking the demo onto a different master.
# MASTER_ACCOUNT_ID=

# Account layout (flat siblings under master):
#   <master>
#   ├── recipes.<master>           ← the recipe book contract
#   ├── recipes-counter.<master>   ← counter (target for Recipe 3)
#   └── bob.<master>                ← nominated handoff recipient (Recipe 4)
#
# Override individual account IDs if you want to run against contracts
# you've deployed elsewhere, or if your master already has an existing
# `counter.<master>` account you can't reclaim.
# ACCOUNT_RECIPES=
# ACCOUNT_COUNTER=
# ACCOUNT_BOB=

# Initial balance per contract (in whole NEAR). Default: 3 NEAR.
# Covers deployment + storage + plenty of runtime headroom for both wasms.
# INITIAL_BALANCE_NEAR=

# Bob's initial balance (non-contract participant; covers tx gas only).
# Default: 0.5 NEAR — enough for hundreds of handoff resume calls.
# BOB_INITIAL_BALANCE_NEAR=

# Per-handoff amount (Recipe 4). Default: 0.01 NEAR = 10000000000000000000000 yocto.
# Small enough that many runs barely move the signer balance.
# HANDOFF_AMOUNT_YOCTO=

# Override RPC endpoints (rare — the defaults track FastNEAR's canonical URLs).
# RPC_SEND=
# RPC_AUDIT=
